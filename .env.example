# Comma-separated list of candidate passwords tried against each encrypted archive.
# The first password that successfully decrypts an archive is used.
# Optional: if all your archives are unencrypted you can leave this unset;
# autoarc always tries an empty password first.
AUTOARC_PASSWORDS=password1,password2,password3

# Optional tracing filter. Try `debug` for verbose extractor diagnostics.
# Lines are printed above the live progress bars without breaking them.
RUST_LOG=info
